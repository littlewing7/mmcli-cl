function setIPandROUTE()
{
		local ib=$(mmcli --modem="$im" |grep -m 1 "Bearer" |cut -d/ -f6)
		declare -A arrayA="( $(mmcli --output-keyvalue --bearer $ib | awk '{ printf "[\"%s\"]=\"%s\" ", $1, $3}' ) )"

		cmd_or_print ip link set up dev "${arrayA[bearer.status.interface]}"

		# remove the actual ip on interface
		cmd_or_print ip a flush "${arrayA[bearer.status.interface]}"
		cmd_or_print ip a replace "${arrayA[bearer.ipv4-config.address]}/${arrayA[bearer.ipv4-config.prefix]}" dev "${arrayA[bearer.status.interface]}"
		cmd_or_print ip r a default via "${arrayA[bearer.ipv4-config.gateway]}"

		case "$IPTYPE" in
     ipv4v6|ipv6)
     # Do stuff
		   cmd_or_print ip -6 a replace "${arrayA[bearer.ipv6-config.address]}/${arrayA[bearer.ipv6-config.prefix]}" dev "${arrayA[bearer.status.interface]}"
		   cmd_or_print ip -6 r a default via "${arrayA[bearer.ipv6-config.gateway]}"
     ;;
    esac
}

function isNetworkFailed()
{
		local state
		state=$(mmcli --modem="$im" | grep -m 1 state | awk '{print $3}' | cut -d\' -f2)
		[[ "$state" == 'registered' ]] && return 1
		return 0
}

function disconnectx()
{
		echo "Disconnecting.."
		local scpid
		scpid=$(pgrep "etup-connection")
			#echo scpid=$scpid
		[[ -n "$scpid" ]] && kill -s 15 "$scpid" && echo Cancelled.
		pkill ping
		echo -n > /dev/shm/NOT-CONNECTED
		cmd_or_print bearer --disconnect
		cmd_or_print mmcli --modem="$im" --simple-disconnect
		cmd_or_print ip r d default
		cmd_or_print ip -6 r d default

		#This disconnects the existing connection(s) for the modem and puts it into a low power mode
		cmd_or_print mmcli --modem="$im" --disable
		sleep 2

		#Resets the modem to the settings it had when it was power cycled. 
		cmd_or_print mmcli --modem="$im" --reset
		sleep 1
		cmd_or_print sv restart ModemManager
		datetime
		btime=$(date +%s)
		exit
}

