wd=$(dirname "$0")

function say() {
    #printf "\n[$(date --iso-8601=seconds)] %b\n" "$1"
    printf "[$(date '+%Y-%m-%d %T')] %b\n" "$1"
    }

function say_overwrite() {
    #printf "\n[$(date --iso-8601=seconds)] %b\n" "$1"
    printf "\033[0K\r[$(date '+%Y-%m-%d %T')] %b" "$1"
    }


function cmd_or_print() { # command
    if [ "$DEBUG" == "True" ] ;then
          say "'$*'"
    fi
    "$@" || say "Failed at: '$*'"
    }

function datetime()
{
	date +"%A, %-d %B %Y - %T %Z"
}

function calc_RX_TX_seconds()
{
          IFN="$1"
          BR1=$(cat /sys/class/net/"${IFN}"/statistics/rx_bytes)
          BT1=$(cat /sys/class/net/"${IFN}"/statistics/tx_bytes)
          sleep 1
          BR2=$(cat /sys/class/net/"${IFN}"/statistics/rx_bytes)
          BT2=$(cat /sys/class/net/"${IFN}"/statistics/tx_bytes)
          TXB=$((BT2 - BT1))
          RXB=$((BR2 - BR1))
}

function ping_test()
{
	TESTNUM=$1
	site=$2

	timestartping="$(date +%T)"
	testping=$(ping -4 -s 1 -c 1 -W 1 -n "$site" | grep "9 bytes" -c )

	if [ "$testping" -eq 0 ]  ; then
		printf "\nTEST%s started at: %s ___ finished at: %s  Bearer Duration: %s Testing site: %s  --- FAILED\n" "$TESTNUM" "$timestartping" "$(date +%T)" "${arrayA[bearer.stats.duration]}" "$site"
	fi
}

function isModemNotExists()
{
		local modm
		modm=$(mmcli --list-modems | grep -m 1 "Modem")
		[[ -z "$modm" ]] && return 0
		return 1
}

function bearer()
{
		local ib
		ib=$(mmcli --modem="$im" |grep -m 1 "Bearer" |cut -d/ -f6)
		[[ -z "$ib" ]] && echo "No any bearer." && return 1

		#say "execute: -->> mmcli --modem=$im --bearer=$ib $@ <<--"
		cmd_or_print mmcli --modem="$im" --bearer="$ib" "$@"
		return 0
}

