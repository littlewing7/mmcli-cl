#!/bin/bash

wd=$(dirname "$0")
cp "$wd/sites.list" .

. "$wd/mmcli_cl_functions"

APN="$1"
IPTYPE="$2"

## setup connection
## -- for my Modem DirectIP-manual connection
##
## (using mmcli 1.18.6)
## <massimo.manzato@@gmail.com>

datetime

say ">> Waiting for modem.."
say -n "please wait"
while true
do
	echo -n "."
	! isModemNotExists && break
	sleep 1
done
echo

im=$(mmcli --list-modems |grep -m 1 "Modem" |cut -d/ -f6 |awk '{print $1}')

say ">> Resetting.."
bearer --disconnect
ip r d default
ip -6 r d default
echo
#mmcli --modem="$im" --set-allowed-modes='any'
#mmcli --modem="$im" --set-allowed-modes='4g'
#mmcli --modem="$im" --set-allowed-modes='3g'

	#echo ">> Registering to home network.."
	#mmcli --modem=$im --3gpp-register-home
	#sleep 5

	#isNetworkFailed && exit

#sleep 1

say ">> Checking bearer.."
#declare -A a="( $(mmcli --modem="$im" --output-keyvalue ) )"
declare -A arrayM="( $(mmcli --modem="$im" --output-keyvalue | awk '{ printf "[\"%s\"]=\"%s\" ", $1, $3}') )"
	#[[ $a == 1 ]] && mmcli --modem=$im --create-bearer="apn=3data,number=*99#,user=3data,password=3data,allow-roaming=1,ip-type=ipv4,allowed-auth=eap|pap|chap" || echo "Bearer already exist."
#[[ "$a" == 1 ]] && mmcli --modem="$im" --create-bearer="apn=indosatgprs,number=*99#,user=indosat,password=indosat,allow-roaming=1,ip-type=ipv4,allowed-auth=eap|pap|chap" || echo "Bearer already exist."
if [ "$((${arrayM[modem.generic.bearers.length]}))" -gt 0 ] ; then
	say "Already exist Bearer: "
	say "${arrayM[modem.generic.bearers.value[1]]}"
else
	#mmcli --modem="$im" --create-bearer="apn=mobile.vodafone.it"
	say ">> Creating bearer: apn=${APN}"
	#cmd_or_print mmcli --modem="$im" --create-bearer="apn=${APN},ip-type=ipv4"
	cmd_or_print mmcli --modem="$im" --create-bearer="apn=${APN},ip-type=${IPTYPE}"
fi

say ">> Connecting.."
try=0
im=$(mmcli --list-modems |grep -m 1 "Modem" |cut -d/ -f6 |awk '{print $1}')
ib=$(mmcli --modem="$im" |grep -m 1 "Bearer" |cut -d/ -f6)
declare -A arrayA="( $(mmcli --output-keyvalue --bearer=$ib | awk '{ printf "[\"%s\"]=\"%s\" ", $1, $3}' ) )"
sleep 1
say "----> Connecting Bearer: ${arrayA[bearer.properties.apn]}"
! bearer -c && exit

while true
do
	sleep 1
	check
	if [ "$result" == 'yes' ]; then
		say 'success.'
		break
	else
		# patch when modem unplugged
		isModemNotExists && exit

		# give up (and then restart again)
		[[ "$try" == 4 ]] && exit

		((try++))
		say "failed. Trying again.. ($try)"

		say ">> Connecting.. in while"
		say ">> Connecting.. in a while : ${arrayA[bearer.properties.apn]}"
		sleep 1
		! bearer --connect && exit
	fi
done

#sleep 2

say ">> Enabling Modem signal-setup"
DEBUG="True" cmd_or_print mmcli --modem="$im" --signal-setup=2

say ">> Setup wwan interface and default route."
setIPandROUTE

