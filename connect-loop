#!/usr/bin/env bash

. "$HOME/.bashrc"

APN="$1"
IPTYPE="$2"
export DEBUG="$3"

if [ $APN"X" == "X" ] || [ $IPTYPE"X" == "X" ]; then
	printf "%s \n"       " EX: bash /projects/MMA/mmcli-cl/connect-loop datacard.tre.it ipv4v6 [True] (optional for DEBUG)"
  printf "%s \n"       " EX: bash /projects/MMA/mmcli-cl/connect-loop mobile.vodafone.it ipv4 "

  say "APN is needed as parameter .....  "
  exit
fi

## connect and autoreconnect
##
##
## (using mmcli 1.18.6)
## <massimo.manzato@gmail.com>

cd  /dev/shm/ || exit
wd=$(dirname $0)
cp "$wd/sites.list" .

. "$wd/mmcli_cl_functions"

cmd_or_print retrieve_bearer_info
#im=$(mmcli --list-modems |grep -m 1 "Modem" |cut -d/ -f6 |awk '{print $1}')
#ib=$(mmcli --modem="$im" |grep -m 1 "Bearer" |cut -d/ -f6)
#declare -A arrayA="( $(mmcli --output-keyvalue --bearer $ib | awk '{ printf "[\"%s\"]=\"%s\" ", $1, $3}' ) )"

say "Initial checks, connected time : %s seconds [30s min refresh intervals]\n" "${arrayA[bearer.stats.duration]}"

while true
do
	check
	if [[ ! $result == 'yes' ]]; then
		say "Check FAILED !! <---- "
		echo -n > /dev/shm/NOT-CONNECTED
		cmd_or_print connectx "$APN" "$IPTYPE"
		sleep 0.5
	fi

  cmd_or_print retrieve_bearer_info

	testping=0
	site1="8.8.4.4"

	calc_RX_TX_seconds "${arrayA[bearer.status.interface]}"
	say_overwrite "BearerUpTime: ${arrayA[bearer.stats.duration]} | RX: $RXB | TX: $TXB        "

	## if data not received line probably is DOWN 
	if [ "$RXB" -eq 0 ] ; then
		printf "\n"
		say " RX are 0 ...  test ISP DNS : ${arrayA[bearer.ipv4-config.dns.value[1]]}"
		if host -W 2 "www.google.com" "${arrayA[bearer.ipv4-config.dns.value[1]]}" > /dev/null; then
		    say "DNS OK "
        testdns="2"
		else
		    say "Restart Bearer ${arrayA[bearer.properties.apn]} at : ${arrayA[bearer.stats.duration]} seconds "
		    cmd_or_print mmcli -b "$ib" --disconnect
		    say "Connect Bearer: ${arrayA[bearer.properties.apn]} "
		    cmd_or_print mmcli -b "$ib" --connect
		    say " ---> Start setup IP and Routes "
		    cmd_or_print setIPandROUTE
		    say " ---> End setup IP and Routes "
		    ## extract the new bearer ???  is this necessary ?
		    ib=$(mmcli --modem="$im" |grep -m 1 "Bearer" |cut -d/ -f6)
		    #echo "DNS FALLITO"
        testdns="0"
		fi

		if [ "$testdns" -eq 0 ]; then
			site1="8.8.8.8"
			say "TEST 3 - ping : $site1"
			cmd_or_print ping_test "3" "$site1"
		fi

		if [ "$testdns" -gt 0 ] || [ "$testping" -gt 0 ] ; then
			#printf "%s -  CONNECTED %s \n" "$(date +%T)" ""
			[[ -e /dev/shm/NOT-CONNECTED ]] && rm /dev/shm/NOT-CONNECTED
			sleep 0.2 &
			wait $!
		else
			#printf "\n%s time: %s  Testing.. %s: " "$(date +%T)" "${arrayA[bearer.stats.duration]}" "$site1"
			#printf "%s -  NOT Connected %s \n" "$(date +%T)" ""
			echo -n > /dev/shm/NOT-CONNECTED
			cmd_or_print bearer --disconnect
			sleep 0.2
		fi
	fi
done

